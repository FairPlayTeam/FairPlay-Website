{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["es2022", "dom"],
    "types": ["node"],
    "isolatedModules": false,
    "incremental": false
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
